@page
@model Blog_Web.Pages.Blog.AddPostModel
@{
    ViewData["Title"] = "Add New Post";
}

<h1>Create New Blog Post</h1>

<div class="row">
    <div class="col-md-8">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="AddPostViewModel.Title"></label>
                <input asp-for="AddPostViewModel.Title" class="form-control" placeholder="Enter an engaging title..." />
                <small id="titleCounter" class="form-text text-muted"></small>
                <span asp-validation-for="AddPostViewModel.Title" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="AddPostViewModel.Content"></label>
                <textarea asp-for="AddPostViewModel.Content" class="form-control" rows="15" placeholder="Write your blog post content here..."></textarea>
                <small id="contentCounter" class="form-text text-muted"></small>
                <span asp-validation-for="AddPostViewModel.Content" class="text-danger"></span>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary">Publish Post</button>
                <a asp-page="/Blog/Dashboard" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h5>Tips for Great Blog Posts</h5>
            </div>
            <div class="card-body">
                <ul class="list-unstyled">
                    <li><i class="fas fa-check text-success"></i> Use a compelling title</li>
                    <li><i class="fas fa-check text-success"></i> Write engaging content</li>
                    <li><i class="fas fa-check text-success"></i> Keep it concise but informative</li>
                    <li><i class="fas fa-check text-success"></i> Use proper formatting</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/js/Blog/addpost.js"></script>
}
