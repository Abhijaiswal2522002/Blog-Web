@page
@model Blog_Web.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="card-header bg-primary text-white text-center py-4 border-0">
                <i class="bi bi-person-circle display-4 mb-2 d-block"></i>
                <h2 class="fw-bold mb-0">Welcome Back</h2>
                <p class="mb-0 opacity-75">Login to access your dashboard</p>
            </div>
            <div class="card-body p-5">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="LoginViewModel.Email" class="form-control rounded-3" id="floatingEmail" placeholder="name@example.com" />
                        <label asp-for="LoginViewModel.Email"><i class="bi bi-envelope me-2"></i> Email address</label>
                        <span asp-validation-for="LoginViewModel.Email" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="LoginViewModel.Password" type="password" class="form-control rounded-3" id="floatingPassword" placeholder="Password" />
                        <label asp-for="LoginViewModel.Password"><i class="bi bi-lock me-2"></i> Password</label>
                        <span asp-validation-for="LoginViewModel.Password" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="rememberMe" />
                            <label class="form-check-label small text-muted" for="rememberMe">Remember me</label>
                        </div>
                        <a href="#" class="small text-decoration-none">Forgot password?</a>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg rounded-3 py-2 shadow-sm fw-bold">Login</button>
                    </div>
                </form>

                <div class="text-center mt-5">
                    <p class="text-muted small">Don't have an account? <a asp-page="/Account/Register" class="fw-bold text-decoration-none">Create one now</a></p>
                </div>
            </div>
        </div>
        
        <div class="text-center mt-4">
            <a asp-page="/Index" class="btn btn-link text-muted text-decoration-none small">
                <i class="bi bi-arrow-left me-1"></i> Back to Homepage
            </a>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/js/Blog/login.js"></script>
}
