@page
@model Blog_Web.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
}

<h1>Register</h1>

<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="RegisterViewModel.Username"></label>
                <input asp-for="RegisterViewModel.Username" class="form-control" />
                <span asp-validation-for="RegisterViewModel.Username" class="text-danger"></span>
                <div id="username-availability" class="small mt-1"></div>
            </div>

            <div class="form-group">
                <label asp-for="RegisterViewModel.Email"></label>
                <input asp-for="RegisterViewModel.Email" class="form-control" />
                <span asp-validation-for="RegisterViewModel.Email" class="text-danger"></span>
                <div id="email-availability" class="small mt-1"></div>
            </div>

            <div class="form-group">
                <label asp-for="RegisterViewModel.Password"></label>
                <input asp-for="RegisterViewModel.Password" class="form-control" />
                <span asp-validation-for="RegisterViewModel.Password" class="text-danger"></span>
                <div id="password-strength" class="small mt-1"></div>
                <div id="password-feedback" class="small text-muted mt-1"></div>
            </div>

            <div class="form-group">
                <label asp-for="RegisterViewModel.ConfirmPassword"></label>
                <input asp-for="RegisterViewModel.ConfirmPassword" class="form-control" />
                <span asp-validation-for="RegisterViewModel.ConfirmPassword" class="text-danger"></span>
                <div id="confirm-password-match" class="small mt-1"></div>
            </div>

            <button type="submit" class="btn btn-primary">Register</button>
        </form>
    </div>
</div>

<p>
    <a asp-page="/Account/Login">Already have an account? Login here.</a>
</p>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/js/Blog/register.js"></script>
}
